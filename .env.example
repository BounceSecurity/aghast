# --- User Configuration ---

# Anthropic API key for Claude AI provider
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-api-key-here

# AI model override (CLI --model takes precedence)
# AGHAST_AI_MODEL=claude-sonnet-4-20250514

# Generic prompt template filename (CLI --generic-prompt takes precedence)
# AGHAST_GENERIC_PROMPT=generic-instructions.md

# Default config directory (CLI --config-dir takes precedence)
# AGHAST_CONFIG_DIR=/path/to/my-checks

# Enable debug output (same as --debug)
# AGHAST_DEBUG=true

# --- Development / Testing ---
# The variables below are for aghast developers and CI pipelines.

# Print the full prompt sent to the AI API (requires --debug)
# AGHAST_DEBUG_PRINTPROMPT=true

# Use a mock AI provider instead of calling the real API (no API key needed).
# Set to 'true' for a default {"issues":[]} response, or set to a file path to
# read the mock response from that file.
# AGHAST_MOCK_AI=true
# AGHAST_MOCK_AI=path/to/response.json

# Path to a SARIF file to use instead of running Semgrep
# AGHAST_MOCK_SEMGREP=path/to/results.sarif

# Skip real Semgrep integration tests (used in CI)
# AGHAST_SKIP_SEMGREP_TESTS=true
